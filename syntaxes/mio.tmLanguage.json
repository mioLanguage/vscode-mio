{
  "name": "mio",
  "scopeName": "source.mio",
  "fileTypes": ["mio"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#imports"
    },
    {
      "include": "#macros"
    },
    {
      "include": "#conditional-compilation"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#string"
    },
    {
      "include": "#number"
    },
    {
      "include": "#boolean"
    },
    {
      "include": "#function-definition"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#struct-definition"
    },
    {
      "include": "#enum-definition"
    },
    {
      "include": "#union-definition"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#labels"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.mio",
          "match": "#.*$"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "keyword.control.import.mio",
          "match": "\\bimport\\b"
        },
        {
          "name": "string.quoted.double.import.mio",
          "match": "\"[^\"]*\""
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "keyword.control.macro.mio",
          "match": "\\bmacro\\b"
        }
      ]
    },
    "conditional-compilation": {
      "patterns": [
        {
          "name": "keyword.control.conditional.mio",
          "match": "@(if|elif|else|end)"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mio",
          "match": "\\b(var|const|if|elif|else|while|for|return|break|continue|goto|def|static|struct|enum|union|true|false|this)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.mio",
          "match": "\\b(i32|i64|u32|u64|f32|f64|bool|char|void|int|float|double)\\b"
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.mio",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mio",
              "match": "\\\\(n|t|r|\\\\|\"|0)"
            }
          ]
        },
        {
          "name": "string.quoted.single.mio",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.mio",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "boolean": {
      "patterns": [
        {
          "name": "constant.language.boolean.mio",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "name": "meta.function.mio",
          "begin": "\\b(def|static\\s+def)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.def.mio"
            }
          },
          "end": "\\{",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.block.begin.mio"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "name": "entity.name.function.mio",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*\\()"
            },
            {
              "name": "storage.type.function-return.mio",
              "match": "\\b(i32|i64|u32|u64|f32|f64|bool|char|void|int|float|double|[a-zA-Z_][a-zA-Z0-9_]*)\\b(?=\\s+[a-zA-Z_])"
            }
          ]
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "meta.function-call.mio",
          "begin": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "beginCaptures": {
            "1": {
              "name": "entity.name.function.mio"
            }
          },
          "end": "\\)",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.parens.end.mio"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#string"
            },
            {
              "include": "#number"
            },
            {
              "include": "#variables"
            },
            {
              "include": "#function-call"
            }
          ]
        }
      ]
    },
    "struct-definition": {
      "patterns": [
        {
          "name": "meta.struct.mio",
          "begin": "\\bstruct\\b",
          "beginCaptures": {
            "0": {
              "name": "keyword.control.struct.mio"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.block.end.mio"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "name": "entity.name.type.struct.mio",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*\\{?)"
            },
            {
              "include": "#struct-fields"
            },
            {
              "include": "#keywords"
            },
            {
              "include": "#types"
            },
            {
              "include": "#function-definition"
            }
          ]
        }
      ]
    },
    "struct-fields": {
      "patterns": [
        {
          "name": "meta.struct-field.mio",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*:\\s*([a-zA-Z_][a-zA-Z0-9_\\[\\]]*);",
          "captures": {
            "1": {
              "name": "variable.other.member.mio"
            },
            "2": {
              "name": "storage.type.mio"
            }
          }
        }
      ]
    },
    "enum-definition": {
      "patterns": [
        {
          "name": "meta.enum.mio",
          "begin": "\\benum\\b",
          "beginCaptures": {
            "0": {
              "name": "keyword.control.enum.mio"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.block.end.mio"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "name": "entity.name.type.enum.mio",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*\\{?)"
            },
            {
              "name": "constant.other.enum.mio",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(\\s*=\\s*[\\d\\-]+)?(?=\\s*[,}])"
            }
          ]
        }
      ]
    },
    "union-definition": {
      "patterns": [
        {
          "name": "meta.union.mio",
          "begin": "\\bunion\\b",
          "beginCaptures": {
            "0": {
              "name": "keyword.control.union.mio"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.block.end.mio"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "name": "entity.name.type.union.mio",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*\\{?)"
            },
            {
              "include": "#struct-fields"
            }
          ]
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "meta.variable.mio",
          "match": "\\b(var|const)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*:\\s*([a-zA-Z_][a-zA-Z0-9_\\[\\]]*)(\\s*=\\s*([^;]+))?;",
          "captures": {
            "1": {
              "name": "keyword.control.var.mio"
            },
            "2": {
              "name": "variable.other.mio"
            },
            "3": {
              "name": "storage.type.mio"
            }
          }
        },
        {
          "name": "meta.variable-inferred.mio",
          "match": "\\b(var|const)\\b\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*=\\s*([^;]+);",
          "captures": {
            "1": {
              "name": "keyword.control.var.mio"
            },
            "2": {
              "name": "variable.other.mio"
            }
          }
        },
        {
          "name": "variable.other.mio",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*[=+\\-*/]|\\s*\\()"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.label.mio",
          "match": ":[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.mio",
          "match": "(\\+\\+|--|\\+=|-=|\\*=|/=|%=|&&|\\|\\||==|!=|<=|>=|\\+|-|\\*|/|%|=|<|>|!)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.mio",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.mio",
          "match": ","
        },
        {
          "name": "punctuation.section.parens.begin.mio",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.mio",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.block.begin.mio",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.mio",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.brackets.begin.mio",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.mio",
          "match": "\\]"
        }
      ]
    }
  }
}